# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model Selection - Use this variable to set your preferred model
# Examples: openai/gpt-4-turbo, anthropic/claude-3-opus, google/gemini-pro
OpenRouterModel=openai/gpt-4-turbo

# OpenRouter Reasoning Feature
# Enable reasoning traces for supported models (e.g., minimax/minimax-m2.5, some Claude models)
# When enabled, the model provides step-by-step reasoning before the final answer
# Note: Only works with specific models that support reasoning
OPENROUTER_REASONING_ENABLED=false

# OpenAI API Configuration (optional - for direct OpenAI usage)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic API Configuration (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Search Configuration
SEARCH_ENGINE=duckduckgo
MAX_SEARCH_RESULTS=5

# Vector Store Configuration
VECTOR_STORE_PATH=./data/vector_store
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/research_assistant.log

# Rate Limiting
MAX_RETRIES=3
RETRY_DELAY=1.0

# Report Configuration
DEFAULT_REPORT_FORMAT=markdown
INCLUDE_CITATIONS=true
